@{
    ViewData["Title"] = "Privacy Policy";
}

<!-- Link the page-specific stylesheet for the privacy page -->
@section Styles {
    <link rel="stylesheet" href="~/css/pages/home/privacy.css" asp-append-version="true" />
}

<div class="privacyPage">
    <!-- Page hero section - introduces the privacy page and gives visitors the main context -->
    <section class="privacyHero" aria-labelledby="privacyHeading">
        <!-- Page hero section - introduces the privacy page and gives visitors the main context -->
        <div class="privacyHeroInner">
            <span class="privacyEyebrow">Privacy Policy</span>
            <h1 class="privacyHeading" id="privacyHeading">How Greenfield Local Hub Handles Personal Data</h1>
            <p class="privacyLead">
                This Privacy Policy explains how Greenfield Local Hub, a UK-based cooperative farmers market,
                collects, uses, stores, and shares personal data when you shop with us, join as a cooperative
                member, contact us, or use our website and services.
            </p>
            <div class="privacyMetaList" aria-label="Privacy policy details">
                <div class="privacyMetaItem">
                    <span class="privacyMetaLabel">Last Updated</span>
                    <span class="privacyMetaValue">23 April 2026</span>
                </div>
                <div class="privacyMetaItem">
                    <span class="privacyMetaLabel">Regulations Covered</span>
                    <span class="privacyMetaValue">UK GDPR, Data Protection Act 2018, and PECR</span>
                </div>
            </div>
        </div>
    </section>

    <div class="privacyContainer">
        <!-- Summary section - highlights the key details before the full page content -->
        <section class="privacySummaryPanel" aria-label="Summary of key privacy points">
            <div class="privacySummaryCard">
                <span class="privacySummaryTitle">Cooperative Focus</span>
                <p class="privacySummaryText">We only use personal data where it is necessary to run the cooperative, fulfil orders, support members, or meet legal duties.</p>
            </div>
            <div class="privacySummaryCard">
                <span class="privacySummaryTitle">Limited Sharing</span>
                <p class="privacySummaryText">We share data only with trusted service providers and only where there is a lawful and proportionate reason to do so.</p>
            </div>
            <div class="privacySummaryCard">
                <span class="privacySummaryTitle">Your Control</span>
                <p class="privacySummaryText">You have rights over your data, including access, correction, restriction, objection, and complaint to the ICO.</p>
            </div>
        </section>

        <div class="privacyContentGrid">
            <!-- Side navigation panel - links to the related sections on this page -->
            <aside class="privacySidePanel" aria-label="Privacy policy navigation">
                <div class="privacySidePanelInner">
                    <p class="privacySideTitle">On This Page</p>
                    <a class="privacySideLink" href="#whoWeAre">Who We Are</a>
                    <a class="privacySideLink" href="#whatPersonalDataWeCollect">What Personal Data We Collect</a>
                    <a class="privacySideLink" href="#howWeUseYourData">How We Use Your Data</a>
                    <a class="privacySideLink" href="#legalBasisForProcessing">Legal Basis For Processing</a>
                    <a class="privacySideLink" href="#dataSharing">Data Sharing</a>
                    <a class="privacySideLink" href="#dataRetention">Data Retention</a>
                    <a class="privacySideLink" href="#yourRights">Your Rights</a>
                    <a class="privacySideLink" href="#cookiesAndTracking">Cookies And Tracking</a>
                    <a class="privacySideLink" href="#contactOurDataProtectionOfficer">Contact Our Data Protection Officer</a>
                    <a class="privacySideLink" href="#complaintsToIco">Complaints To ICO</a>
                </div>
            </aside>

            <div class="privacySections">
                <!-- Content section - groups related privacy content together -->
                <section class="privacySection" id="whoWeAre">
                    <span class="privacySectionEyebrow">Who We Are</span>
                    <h2 class="privacySectionHeading">Greenfield Local Hub As A Community-Owned Cooperative</h2>
                    <p class="privacyParagraph">
                        Greenfield Local Hub is a UK-based cooperative farmers market that connects local producers with
                        customers and community members. We operate as a community-owned organisation focused on ethical
                        sourcing, fair producer participation, and transparent local food distribution.
                    </p>
                    <p class="privacyParagraph">
                        For the purposes of UK data protection law, Greenfield Local Hub is the data controller for the
                        personal data described in this Privacy Policy. Our principal trading and registered contact
                        address is 14 Market Square, Greenfield, Midshire, MK12 4AB, United Kingdom.
                    </p>
                </section>

                <!-- Content section - groups related privacy content together -->
                <section class="privacySection" id="whatPersonalDataWeCollect">
                    <span class="privacySectionEyebrow">What We Collect</span>
                    <h2 class="privacySectionHeading">What Personal Data We Collect</h2>
                    <p class="privacyParagraph">
                        Depending on how you interact with us, we may collect and process the following categories of personal data:
                    </p>
                    <div class="privacyListCard">
                        <ul class="privacyList">
                            <li class="privacyListItem">Identity and contact details, including your name, billing address, delivery address, email address, and telephone number.</li>
                            <li class="privacyListItem">Order and account information, including products ordered, delivery instructions, basket history, account login information, and customer service records.</li>
                            <li class="privacyListItem">Payment-related information, including payment method details, payment status, and transaction references. Card data is normally processed by our payment providers rather than stored in full by us.</li>
                            <li class="privacyListItem">Cooperative membership data, including membership status, shareholding or membership contribution records, voting eligibility, attendance at meetings, and communications relating to member participation.</li>
                            <li class="privacyListItem">Technical and usage data, including IP address, browser type, device information, cookie preferences, and website interaction data where cookies or similar technologies are used.</li>
                            <li class="privacyListItem">Communications data, including enquiries, complaints, feedback, accessibility requests, and marketing preferences.</li>
                        </ul>
                    </div>
                </section>

                <!-- Content section - groups related privacy content together -->
                <section class="privacySection" id="howWeUseYourData">
                    <span class="privacySectionEyebrow">How We Use Data</span>
                    <h2 class="privacySectionHeading">How We Use Your Data</h2>
                    <div class="privacyFeatureGrid">
                        <article class="privacyFeatureCard">
                            <h3 class="privacyFeatureHeading">Order Fulfilment</h3>
                            <p class="privacyFeatureText">To process orders, arrange delivery or collection, manage substitutions, issue receipts, and provide customer support.</p>
                        </article>
                        <article class="privacyFeatureCard">
                            <h3 class="privacyFeatureHeading">Cooperative Communications</h3>
                            <p class="privacyFeatureText">To communicate with members about governance, meetings, voting, subscriptions, producer updates, and cooperative operations.</p>
                        </article>
                        <article class="privacyFeatureCard">
                            <h3 class="privacyFeatureHeading">Legal And Administrative Duties</h3>
                            <p class="privacyFeatureText">To keep financial records, prevent fraud, respond to legal requests, and comply with tax, accounting, consumer, and food-traceability obligations.</p>
                        </article>
                        <article class="privacyFeatureCard">
                            <h3 class="privacyFeatureHeading">Service Improvement</h3>
                            <p class="privacyFeatureText">To review website performance, improve our platform, understand customer demand, and develop products and cooperative services.</p>
                        </article>
                    </div>
                    <p class="privacyParagraph">
                        Where permitted under PECR and UK GDPR, we may also send service messages and, where appropriate
                        consent or soft opt-in rules apply, marketing communications about seasonal produce, cooperative
                        news, market events, and producer updates.
                    </p>
                </section>

                <!-- Content section - groups related privacy content together -->
                <section class="privacySection" id="legalBasisForProcessing">
                    <span class="privacySectionEyebrow">Lawful Basis</span>
                    <h2 class="privacySectionHeading">Legal Basis For Processing Under UK GDPR Article 6</h2>
                    <div class="privacyListCard privacyListCardAccent">
                        <ul class="privacyList">
                            <li class="privacyListItem"><strong>Contract:</strong> where processing is necessary to fulfil an order, provide an account, or administer your cooperative membership.</li>
                            <li class="privacyListItem"><strong>Legal Obligation:</strong> where we must keep records, respond to lawful requests, comply with consumer law, tax law, accounting rules, or food safety and traceability requirements.</li>
                            <li class="privacyListItem"><strong>Legitimate Interests:</strong> where processing is necessary to manage the cooperative responsibly, prevent misuse, improve services, and communicate efficiently, provided your rights do not override those interests.</li>
                            <li class="privacyListItem"><strong>Consent:</strong> where required for certain cookies, analytics technologies, or electronic marketing communications under PECR.</li>
                        </ul>
                    </div>
                </section>

                <!-- Content section - groups related privacy content together -->
                <section class="privacySection" id="dataSharing">
                    <span class="privacySectionEyebrow">Sharing</span>
                    <h2 class="privacySectionHeading">Data Sharing</h2>
                    <p class="privacyParagraph">
                        We only share personal data where this is necessary for the operation of Greenfield Local Hub or
                        where we are legally required to do so. Recipients may include:
                    </p>
                    <div class="privacyListCard">
                        <ul class="privacyList">
                            <li class="privacyListItem">Payment processors and payment service providers, to take and verify payments securely.</li>
                            <li class="privacyListItem">Delivery partners and collection coordinators, where delivery or fulfilment details are needed to complete your order.</li>
                            <li class="privacyListItem">Producers or authorised cooperative personnel, where strictly necessary to prepare, pack, trace, or resolve issues relating to your order or membership.</li>
                            <li class="privacyListItem">Professional advisers, auditors, insurers, software hosting providers, and IT support services where they process data under appropriate contractual protections.</li>
                            <li class="privacyListItem">Public authorities, regulators, or law enforcement bodies where disclosure is required by law or reasonably necessary to protect rights, safety, or the integrity of the cooperative.</li>
                        </ul>
                    </div>
                    <p class="privacyParagraph">
                        We do not sell personal data to third parties.
                    </p>
                </section>

                <!-- Content section - groups related privacy content together -->
                <section class="privacySection" id="dataRetention">
                    <span class="privacySectionEyebrow">Retention</span>
                    <h2 class="privacySectionHeading">Data Retention</h2>
                    <p class="privacyParagraph">
                        We keep personal data only for as long as necessary for the purposes described in this Privacy Policy,
                        including to meet legal, accounting, and dispute-resolution requirements. Typical retention periods include:
                    </p>
                    <div class="privacyTimeline">
                        <article class="privacyTimelineItem">
                            <span class="privacyTimelinePeriod">Up To 6 Years</span>
                            <p class="privacyTimelineText">Order records, invoices, and payment records, usually retained after the end of the relevant financial year to meet accounting, tax, and contractual record-keeping obligations in the UK.</p>
                        </article>
                        <article class="privacyTimelineItem">
                            <span class="privacyTimelinePeriod">Up To 6 Years</span>
                            <p class="privacyTimelineText">Complaint, dispute, and customer service records where needed to establish, defend, or manage legal claims.</p>
                        </article>
                        <article class="privacyTimelineItem">
                            <span class="privacyTimelinePeriod">Membership Term Plus 6 Years</span>
                            <p class="privacyTimelineText">Core cooperative membership and governance records where necessary for legal compliance, audit history, and institutional record keeping.</p>
                        </article>
                        <article class="privacyTimelineItem">
                            <span class="privacyTimelinePeriod">Shorter Periods</span>
                            <p class="privacyTimelineText">Cookie and analytics data retained in line with our cookie settings, consent choices, and operational needs.</p>
                        </article>
                    </div>
                </section>

                <!-- Content section - groups related privacy content together -->
                <section class="privacySection" id="yourRights">
                    <span class="privacySectionEyebrow">Your Rights</span>
                    <h2 class="privacySectionHeading">Your Rights Under UK GDPR</h2>
                    <p class="privacyParagraph">
                        Subject to legal conditions and exemptions, you have the right to:
                    </p>
                    <div class="privacyRightsGrid">
                        <article class="privacyRightsCard"><h3 class="privacyRightsHeading">Access</h3><p class="privacyRightsText">Request a copy of the personal data we hold about you.</p></article>
                        <article class="privacyRightsCard"><h3 class="privacyRightsHeading">Rectification</h3><p class="privacyRightsText">Ask us to correct incomplete or inaccurate information.</p></article>
                        <article class="privacyRightsCard"><h3 class="privacyRightsHeading">Erasure</h3><p class="privacyRightsText">Request deletion where there is no overriding reason for us to continue processing.</p></article>
                        <article class="privacyRightsCard"><h3 class="privacyRightsHeading">Restriction</h3><p class="privacyRightsText">Ask us to limit how we use your personal data in certain circumstances.</p></article>
                        <article class="privacyRightsCard"><h3 class="privacyRightsHeading">Portability</h3><p class="privacyRightsText">Receive certain personal data in a structured, commonly used format where the right applies.</p></article>
                        <article class="privacyRightsCard"><h3 class="privacyRightsHeading">Objection</h3><p class="privacyRightsText">Object to processing carried out on the basis of legitimate interests or for direct marketing.</p></article>
                    </div>
                </section>

                <!-- Content section - groups related privacy content together -->
                <section class="privacySection" id="cookiesAndTracking">
                    <span class="privacySectionEyebrow">Cookies</span>
                    <h2 class="privacySectionHeading">Cookies And Tracking</h2>
                    <p class="privacyParagraph">
                        We use cookies and similar technologies to operate the website, remember preferences, understand
                        usage patterns, and improve the customer experience. Where cookies are not strictly necessary,
                        we seek consent in line with PECR before placing them on your device.
                    </p>
                    <p class="privacyParagraph">
                        You can manage cookie choices through your browser settings and any cookie controls we provide
                        on the site. Blocking some cookies may affect account access, shopping basket features, or parts
                        of the website that rely on saved preferences.
                    </p>
                </section>

                <!-- Content section - groups related privacy content together -->
                <section class="privacySection" id="contactOurDataProtectionOfficer">
                    <span class="privacySectionEyebrow">Contact</span>
                    <h2 class="privacySectionHeading">Contact Our Data Protection Officer</h2>
                    <div class="privacyContactCard">
                        <p class="privacyContactLine"><strong>Data Protection Officer</strong></p>
                        <p class="privacyContactLine">Greenfield Local Hub</p>
                        <p class="privacyContactLine">14 Market Square, Greenfield, Midshire, MK12 4AB, United Kingdom</p>
                        <p class="privacyContactLine">Email: privacy@greenfieldlocalhub.co.uk</p>
                        <p class="privacyContactLine">Telephone: 01234 567 890</p>
                    </div>
                    <p class="privacyParagraph">
                        Please contact us if you would like to exercise your rights, update your information, or ask how
                        we handle personal data within the cooperative.
                    </p>
                </section>

                <!-- Content section - groups related privacy content together -->
                <section class="privacySection" id="complaintsToIco">
                    <span class="privacySectionEyebrow">Complaints</span>
                    <h2 class="privacySectionHeading">Complaints To The Information Commissioner's Office</h2>
                    <p class="privacyParagraph">
                        If you are dissatisfied with how we handle your personal data, we would appreciate the opportunity
                        to address your concerns first. You also have the right to complain to the Information
                        Commissioner's Office, the UK supervisory authority for data protection matters.
                    </p>
                    <div class="privacyNoticeCard">
                        <p class="privacyNoticeText">
                            Information Commissioner's Office: Wycliffe House, Water Lane, Wilmslow, Cheshire, SK9 5AF.
                            Website: ico.org.uk. Telephone: 0303 123 1113.
                        </p>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>
