@using GreenfieldLocalHubWebApp.Models
@model List<loyaltyTransaction>

@{
    ViewData["Title"] = "Transaction History";
    Layout = "_AccountLayout";
}

<!-- Link the page-specific stylesheet for the loyalty accounts transaction history page -->
@section Styles {
    <link rel="stylesheet" href="~/css/pages/loyaltyAccounts/transactionHistory.css" asp-append-version="true" />
}


<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Transaction History</h1>
        <a asp-action="Index" class="btn btn-outline-primary">Back to Dashboard</a>
    </div>

    <!-- Panel section - groups related information in a focused content block -->
    <div class="card mb-4">
        <div class="card-body">
            <!-- Form section - collects and submits the fields for this loyalty accounts transaction history workflow -->
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Transaction Type</label>
                    <select name="transactionType" class="form-select">
                        <option value="All">All</option>
                        <option value="Earn" selected="@(ViewBag.CurrentType == "Earn")">Earned</option>
                        <option value="Redeem" selected="@(ViewBag.CurrentType == "Redeem")">Redeemed</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary">Filter</button>
                    <a asp-action="TransactionHistory" class="btn btn-secondary ms-2">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Transactions table - lists each loyalty transaction with its key details -->
    <div class="table-responsive">
        <!-- Loyalty account table - lists each record with its available actions -->
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Transaction Type</th>
                    <th>Points</th>
                    <th>Order ID</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                <!-- Conditional section - shows this block only when the matching page state is true -->
                @if (Model.Any())
                {
                    <!-- Loop through each loyalty account record passed in from the controller -->
                    @foreach (var transaction in Model)
                    {
                        <tr>
                            <td>@transaction.transactionDate.ToString("dd MMM yyyy HH:mm")</td>
                            <td>
                                <!-- Conditional section - shows this block only when the matching page state is true -->
                                @if (transaction.transactionType == "Earn")
                                {
                                    <span class="badge bg-success">Earned</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Redeemed</span>
                                }
                            </td>
                            <td class="@(transaction.transactionType == "Earn" ? "text-success" : "text-danger")">
                                @(transaction.transactionType == "Earn" ? "+" : "-")@transaction.loyaltyPoints
                            </td>
                            <td>
                                <!-- Conditional section - shows this block only when the matching page state is true -->
                                @if (transaction.ordersId.HasValue)
                                {
                                    <a href="@Url.Action("Details", "orders", new { id = transaction.ordersId })">#@transaction.ordersId</a>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                            <td>
                                <!-- Conditional section - shows this block only when the matching page state is true -->
                                @if (transaction.ordersId.HasValue)
                                {
                                    <a href="@Url.Action("Details", "orders", new { id = transaction.ordersId })" class="btn btn-sm btn-outline-primary">View Order</a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4">No transactions found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Conditional section - shows this block only when the matching page state is true -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <!-- Conditional section - shows this block only when the matching page state is true -->
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("TransactionHistory", new { page = ViewBag.CurrentPage - 1, transactionType = ViewBag.CurrentType })">Previous</a>
                    </li>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("TransactionHistory", new { page = i, transactionType = ViewBag.CurrentType })">@i</a>
                    </li>
                }

                <!-- Conditional section - shows this block only when the matching page state is true -->
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("TransactionHistory", new { page = ViewBag.CurrentPage + 1, transactionType = ViewBag.CurrentType })">Next</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <!-- Content wrapper - groups related loyalty accounts transaction history content together -->
    <div class="alert alert-info mt-4">
        <strong>Summary:</strong> Total Points Earned: @ViewBag.TotalPointsEarned | Total Points Redeemed: @ViewBag.TotalPointsRedeemed
    </div>
</div>
