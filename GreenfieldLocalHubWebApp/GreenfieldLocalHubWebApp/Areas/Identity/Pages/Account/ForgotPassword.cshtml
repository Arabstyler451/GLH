@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<style>
    .forgotPage {
        max-width: 1320px;
        margin: 0 auto;
        padding: 1rem 0 2rem;
    }

    .forgotCard {
        max-width: 560px;
        border: 1px solid var(--border);
        background: var(--white);
        box-shadow: var(--shadow-sm);
    }

    .forgotCardHeader {
        padding: 2rem 2rem 1.35rem;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(135deg, var(--green-faint) 0%, var(--white) 100%);
    }

    .forgotEyebrow {
        display: inline-block;
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--brown);
        margin-bottom: .55rem;
    }

    .forgotTitle {
        font-family: var(--font-serif);
        font-size: clamp(1.7rem, 3vw, 2.3rem);
        font-weight: 600;
        color: var(--green-dark);
        line-height: 1.2;
        margin: 0;
    }

    .forgotSubtitle {
        font-size: .92rem;
        color: var(--text-muted);
        line-height: 1.7;
        margin: .7rem 0 0;
        max-width: 42rem;
    }

    .forgotDivider {
        border: 0;
        border-top: 1px solid var(--border);
        margin: 0;
    }

    .forgotCardBody {
        padding: 1.6rem 2rem 2rem;
    }

    .forgotStatus[role="alert"] {
        background: #fde8e8;
        border-left: 3px solid #a0281e;
        color: #a0281e;
        padding: .9rem 1rem;
        font-size: .84rem;
        line-height: 1.55;
        margin-bottom: 1.2rem;
    }

    .forgotField {
        margin-bottom: 1.2rem;
    }

    .forgotField .form-control,
    .forgotField .form-label {
        font-family: var(--font-sans);
    }

    .forgotField .form-control {
        border: 1.5px solid var(--border);
        background: var(--white);
        color: var(--text);
        min-height: 58px;
    }

    .forgotField .form-control:focus {
        border-color: var(--green);
        box-shadow: 0 0 0 3px rgba(27,77,63,.08);
    }

    .forgotField .form-label {
        color: var(--text-muted);
    }

    .forgotField .text-danger {
        font-size: .75rem;
    }

    .forgotButton {
        border: none;
        border-radius: 0;
        background: var(--green);
        color: var(--white);
        font-family: var(--font-sans);
        font-size: .9rem;
        font-weight: 600;
        letter-spacing: .02em;
        padding: .95rem 1.25rem;
        transition: var(--transition);
    }

    .forgotButton:hover,
    .forgotButton:focus {
        background: var(--green-light);
        color: var(--white);
    }

    @@media (max-width: 768px) {
        .forgotPage {
            padding: .5rem 0 1.5rem;
        }

        .forgotCardHeader,
        .forgotCardBody {
            padding-left: 1.4rem;
            padding-right: 1.4rem;
        }
    }
</style>

<div class="forgotPage">
    <div class="forgotCard">
        <div class="forgotCardHeader">
            <span class="forgotEyebrow">Account Support</span>
            <h1 class="forgotTitle">@ViewData["Title"]</h1>
            <h2 class="forgotSubtitle">Enter your email and we will send password reset instructions for your Greenfield Local Hub account.</h2>
        </div>
        <hr class="forgotDivider" />
        <div class="forgotCardBody">
            <div class="row">
                <div class="col-md-12">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger forgotStatus" role="alert"></div>
            <div class="form-floating mb-3 forgotField">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="form-label"></label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary forgotButton">Reset Password</button>
        </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
