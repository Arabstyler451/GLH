@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
<!-- Content section - groups related account layout content together -->
@RenderSection("Styles", required: false)

@{

    Layout = "_Layout.cshtml";


    var user = await SignInManager.UserManager.GetUserAsync(User);
    var userName = user?.UserName?.Split('@')[0];
    // Capitalise first letter for the greeting
    var greeting = string.IsNullOrEmpty(userName)
        ? "your account"
        : char.ToUpper(userName[0]) + userName.Substring(1);
}

<!-- Link the page-specific stylesheet for the account layout page -->
@section Styles {
    <link rel="stylesheet" href="~/css/accountLayout.css" asp-append-version="true" />
}

<!-- Page hero section - introduces the account layout page and gives visitors the main context -->
<div class="account-page-hero">
    <!-- Page hero section - introduces the account layout page and gives visitors the main context -->
    <div class="account-page-hero-inner">
        <span class="account-page-eyebrow">My Account</span>
        <h1>Welcome back, @greeting</h1>
        <p>Manage your profile, orders, and loyalty rewards.</p>
    </div>
</div>

<!-- Content wrapper - groups related account layout content together -->
<div class="account-section">
    <div class="account-container">
        <div class="account-layout">

            <!-- Partial view - renders shared markup used by this page -->
            <partial name="~/Areas/Identity/Pages/Account/Manage/_ManageNav.cshtml" />

            <!-- Page content area - renders the selected account management page -->
            <div>
                <!-- Render body call - outputs the content for the current page -->
                @RenderBody()
            </div>

        </div>
    </div>
</div>

<!-- Scripts section - loads validation or page-specific scripts for this page -->
@section Scripts {
    @RenderSection("Scripts", required: false)
}
