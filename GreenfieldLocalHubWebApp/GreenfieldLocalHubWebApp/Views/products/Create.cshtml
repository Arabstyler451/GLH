@model GreenfieldLocalHubWebApp.Models.products

@{
    ViewData["Title"] = "Add Product";
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet" />

@section Styles {
    <link rel="stylesheet" href="~/css/pages/products/create.css" asp-append-version="true" />
}

<div class="glh-create-root">

    <!-- PAGE HERO -->
    <div class="glh-hero">
        <div class="glh-hero-inner">
            <nav class="glh-breadcrumb" aria-label="Breadcrumb">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <span class="glh-breadcrumb-sep">›</span>
                <a asp-controller="producerDashboard" asp-action="Index">Dashboard</a>
                <span class="glh-breadcrumb-sep">›</span>
                <span aria-current="page">Add Product</span>
            </nav>
            <span class="glh-eyebrow">Product Management</span>
            <h1>Add New Product</h1>
        </div>
    </div>

    <div class="glh-section">

        <!-- PROGRESS STEPS -->
        <div class="glh-progress" aria-label="Form progress">
            <div class="glh-progress-step active">
                <span class="glh-progress-dot">1</span>
                Details
            </div>
            <div class="glh-progress-line"></div>
            <div class="glh-progress-step active">
                <span class="glh-progress-dot">2</span>
                Stock
            </div>
            <div class="glh-progress-line"></div>
            <div class="glh-progress-step active">
                <span class="glh-progress-dot">3</span>
                Image
            </div>
        </div>

        <form asp-action="Create" method="post" id="createForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="glh-alert-error"></div>

            <div class="glh-grid">

                <!-- LEFT COLUMN -->
                <div>

                    <!-- Card 1: Core Details -->
                    <div class="glh-card">
                        <div class="glh-card-header">
                            <span class="glh-card-num">1</span>
                            <h2>Product Details</h2>
                        </div>
                        <div class="glh-card-body">

                            <div class="glh-form-group">
                                <label asp-for="productName" class="glh-form-label">Product Name</label>
                                <input asp-for="productName" class="glh-form-input"
                                       placeholder="e.g. Organic Free Range Eggs"
                                       oninput="updateChecklist()" />
                                <span asp-validation-for="productName" class="glh-field-error"></span>
                            </div>

                            <div class="glh-form-group">
                                <label asp-for="productDescription" class="glh-form-label">Description</label>
                                <textarea asp-for="productDescription" class="glh-form-textarea"
                                          placeholder="Describe your product — origin, quality, taste, certifications…"
                                          oninput="updateChecklist()"></textarea>
                                <span asp-validation-for="productDescription" class="glh-field-error"></span>
                            </div>

                            <div class="glh-form-row">
                                <div class="glh-form-group">
                                    <label asp-for="productPrice" class="glh-form-label">Price (£)</label>
                                    <input asp-for="productPrice" type="number" step="0.01" min="0"
                                           class="glh-form-input" placeholder="0.00"
                                           oninput="updateChecklist()" />
                                    <span asp-validation-for="productPrice" class="glh-field-error"></span>
                                </div>
                                <div class="glh-form-group">
                                    <label asp-for="productUnit" class="glh-form-label">Unit</label>
                                    <input asp-for="productUnit" class="glh-form-input"
                                           placeholder="e.g. kg, litre, each" />
                                    <span asp-validation-for="productUnit" class="glh-field-error"></span>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- Card 2: Stock & Category -->
                    <div class="glh-card">
                        <div class="glh-card-header">
                            <span class="glh-card-num">2</span>
                            <h2>Stock &amp; Category</h2>
                        </div>
                        <div class="glh-card-body">

                            <div class="glh-form-row">
                                <div class="glh-form-group">
                                    <label asp-for="stockQuantity" class="glh-form-label">Stock Quantity</label>
                                    <input asp-for="stockQuantity" type="number" min="0"
                                           class="glh-form-input" placeholder="0"
                                           oninput="updateChecklist()" />
                                    <span asp-validation-for="stockQuantity" class="glh-field-error"></span>
                                </div>
                                <div class="glh-form-group">
                                    <label asp-for="categoriesId" class="glh-form-label">Category</label>
                                    <div class="glh-select-wrap">
                                        <select asp-for="categoriesId"
                                                asp-items="ViewBag.categoriesId"
                                                class="glh-form-select"
                                                onchange="updateChecklist()">
                                            <option value="">— Select category —</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="categoriesId" class="glh-field-error"></span>
                                </div>
                            </div>

                            <div class="glh-form-group">
                                <label class="glh-form-label">Availability</label>
                                <div class="glh-toggle-wrap">
                                    <label class="glh-toggle">
                                        <input asp-for="productAvailability" type="checkbox" checked />
                                        <span class="glh-toggle-slider"></span>
                                    </label>
                                    <div>
                                        <div class="glh-toggle-label">Available for purchase</div>
                                        <div class="glh-toggle-sub">Toggle off to save as draft</div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- Card 3: Image -->
                    <div class="glh-card">
                        <div class="glh-card-header">
                            <span class="glh-card-num">3</span>
                            <h2>Product Image</h2>
                        </div>
                        <div class="glh-card-body">
                            <div class="glh-form-group">
                                <label asp-for="productImage" class="glh-form-label">Image URL</label>
                                <input asp-for="productImage" class="glh-form-input"
                                       placeholder="https://example.com/image.jpg"
                                       oninput="previewImage(this.value); updateChecklist()" />
                                <p class="glh-form-hint">Paste a direct link to your product image. Supported: JPG, PNG, WebP.</p>
                                <span asp-validation-for="productImage" class="glh-field-error"></span>
                            </div>
                            <img id="imgPreview" class="glh-img-preview" alt="Preview"
                                 onerror="this.style.display='none'" />
                            <div id="imgPlaceholder" class="glh-img-placeholder">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                                    <circle cx="8.5" cy="8.5" r="1.5"/>
                                    <polyline points="21 15 16 10 5 21"/>
                                </svg>
                                <span>Image preview</span>
                            </div>
                        </div>
                    </div>


                    @if (User.IsInRole("Admin") || User.IsInRole("Developer"))
{
    <div class="glh-card">
        <div class="glh-card-header">
            <span class="glh-card-num">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
            </span>
            <h2>Assign Producer</h2>
        </div>
        <div class="glh-card-body">
            <div class="glh-form-group">
                <label asp-for="producersId" class="glh-form-label">Producer</label>
                <div class="glh-select-wrap">
                    <select asp-for="producersId"
                            asp-items="ViewBag.producersId"
                            class="glh-form-select">
                        <option value="">— Select producer —</option>
                    </select>
                </div>
                <span asp-validation-for="producersId" class="glh-field-error"></span>
            </div>
        </div>
    </div>
}

                </div>

                <!-- RIGHT COLUMN: SIDEBAR -->
                <aside>
                    <div class="glh-sidebar-card">
                        <h2 class="glh-sidebar-title">Before You Publish</h2>

                        <ul class="glh-checklist" id="checklist">
                            <li id="chk-name">
                                <span class="glh-checklist-dot"></span>
                                Product name entered
                            </li>
                            <li id="chk-desc">
                                <span class="glh-checklist-dot"></span>
                                Description added
                            </li>
                            <li id="chk-price">
                                <span class="glh-checklist-dot"></span>
                                Price set
                            </li>
                            <li id="chk-stock">
                                <span class="glh-checklist-dot"></span>
                                Stock quantity entered
                            </li>
                            <li id="chk-cat">
                                <span class="glh-checklist-dot"></span>
                                Category selected
                            </li>
                            <li id="chk-img">
                                <span class="glh-checklist-dot"></span>
                                Image URL provided
                            </li>
                        </ul>

                        <button type="submit" class="glh-btn glh-btn-primary">
                            Publish Product
                        </button>
                        <a asp-controller="producerDashboard" asp-action="Index"
                           asp-route-activeTab="products"
                           class="glh-btn glh-btn-ghost">
                            Cancel
                        </a>

                        <div class="glh-info-box">
                            <strong>Tip</strong>
                            Products go live immediately once published. You can edit or hide them at any time from your dashboard.
                        </div>
                    </div>
                </aside>

            </div>
        </form>
    </div>
</div>


@section Scripts {
    <script src="~/js/pages/products/create.js" asp-append-version="true"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
