@model GreenfieldLocalHubWebApp.Models.products

@{
    ViewData["Title"] = "Delete Product";
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet" />

@section Styles {
    <link rel="stylesheet" href="~/css/pages/products/delete.css" asp-append-version="true" />
}

<div class="glh-delete-root">

    <!-- PAGE HERO -->
    <div class="glh-hero">
        <div class="glh-hero-inner">
            <nav class="glh-breadcrumb" aria-label="Breadcrumb">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <span class="glh-breadcrumb-sep">›</span>
                <a asp-controller="producerDashboard" asp-action="Index"
                   asp-route-activeTab="products">Dashboard</a>
                <span class="glh-breadcrumb-sep">›</span>
                <span aria-current="page">Delete Product</span>
            </nav>
            <span class="glh-eyebrow">Danger Zone</span>
            <h1>Delete Product</h1>
        </div>
    </div>

    <div class="glh-section">

        <!-- WARNING BANNER -->
        <div class="glh-warning-banner" role="alert">
            <div class="glh-warning-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 9v4M12 17h.01"/>
                    <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
            </div>
            <div class="glh-warning-text">
                <strong>This action cannot be undone</strong>
                <p>Permanently deleting this product will remove it from the shop and all associated data. Please review the details below before confirming.</p>
            </div>
        </div>

        <!-- PRODUCT PREVIEW CARD -->
        <div class="glh-product-card">
            @if (!string.IsNullOrEmpty(Model.productImage))
            {
                <img src="@Model.productImage"
                     alt="@Model.productName"
                     class="glh-product-img"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                <div class="glh-product-img-placeholder" style="display:none;">No Image</div>
            }
            else
            {
                <div class="glh-product-img-placeholder">No Image</div>
            }

            <div class="glh-product-info">
                @if (Model.categories != null)
                {
                    <p class="glh-product-category">@Model.categories.categoryName</p>
                }
                <h2 class="glh-product-name">@Model.productName</h2>

                <div class="glh-meta-grid">
                    <div class="glh-meta-item">
                        <span class="glh-meta-label">Price</span>
                        <span class="glh-meta-value">£@Model.productPrice.ToString("0.00") / @(Model.productUnit ?? "unit")</span>
                    </div>
                    <div class="glh-meta-item">
                        <span class="glh-meta-label">Stock</span>
                        <span class="glh-meta-value">@Model.stockQuantity units</span>
                    </div>
                    <div class="glh-meta-item">
                        <span class="glh-meta-label">Producer</span>
                        <span class="glh-meta-value">@(Model.producers?.producerName ?? "—")</span>
                    </div>
                    <div class="glh-meta-item">
                        <span class="glh-meta-label">Availability</span>
                        <span class="glh-avail-pill @(Model.productAvailability ? "in" : "out")">
                            @(Model.productAvailability ? "Available" : "Hidden")
                        </span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.productDescription))
                {
                    <p style="font-size:.83rem;color:var(--text-muted);margin-top:1rem;
                              line-height:1.65;border-top:1px solid var(--border);padding-top:.9rem;">
                        @Model.productDescription
                    </p>
                }
            </div>
        </div>

        <!-- ACTION ROW -->
        <div class="glh-action-row">
            <form asp-action="Delete" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="productsId" />
                <button type="submit" class="glh-btn glh-btn-danger">
                    Yes, Delete Permanently
                </button>
            </form>

            <a asp-controller="producerDashboard"
               asp-action="Index"
               asp-route-activeTab="products"
               class="glh-btn glh-btn-ghost">
                Cancel — Keep Product
            </a>
        </div>

    </div>
</div>