@using GreenfieldLocalHubWebApp.Models
@model loyaltyAccount

@{
    ViewData["Title"] = "My Loyalty Rewards";
    Layout = "_AccountLayout";
}

<!-- Link the page-specific stylesheet for the loyalty accounts index page -->
@section Styles {
    <link rel="stylesheet" href="~/css/pages/loyaltyAccounts/index.css" asp-append-version="true" />
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <!-- Loyalty card -->
            <div class="loyalty-card">
                <div class="loyalty-tier-label">@Model.loyaltyTier Member</div>
                <div class="loyalty-points">@Model.pointsBalance.ToString("N0")</div>
                <div class="loyalty-worth">points — worth <strong>£@ViewBag.PointsMonetaryValue.ToString("F2")</strong> in discounts</div>
                <div class="points-bar">
                    <div class="points-bar-fill" style="width: @ViewBag.TierProgress%;"></div>
                </div>
                <div class="points-meta">
                    <span>@Model.loyaltyTier</span>
                    <span>@ViewBag.PointsToNextTier points to @ViewBag.NextTierName</span>
                </div>
            </div>

            <!-- Content wrapper - groups related loyalty accounts index content together -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-label">Total Points Earned</div>
                        <div class="stat-value">@ViewBag.TotalPointsEarned.ToString("N0")</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-label">Total Points Redeemed</div>
                        <div class="stat-value">@ViewBag.TotalPointsRedeemed.ToString("N0")</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-label">Current Tier</div>
                        <div class="stat-value">@Model.loyaltyTier</div>
                    </div>
                </div>
            </div>

            <!-- Content section - groups related loyalty accounts index content together -->
            <h3 class="mt-4 mb-3">Redeem Offers</h3>
            <div class="offer-grid">
                <!-- Conditional section - shows this block only when the matching page state is true -->
                @if (ViewBag.AvailableOffers != null && ViewBag.AvailableOffers.Count > 0)
                {
                    <!-- Loop through each loyalty account record passed in from the controller -->
                    @foreach (var offer in ViewBag.AvailableOffers)
                    {
                        <div class="offer-card">
                            <div class="offer-card-title">@offer.Title</div>
                            <div class="offer-card-desc">@offer.Description</div>
                            <div class="offer-cost">@offer.PointsCost pts</div>

                            <!-- Conditional section - shows this block only when the matching page state is true -->
                            @if (offer.IsRedeemed)
                            {
                                // Already redeemed - show disabled button
                                <button type="button" class="btn btn-redeemed btn-sm w-100 mt-3" disabled>
                                    ✓ Redeemed
                                </button>
                            }
                            else if (offer.IsAvailable)
                            {
                        // Available - show redeem button
                                <form asp-action="RedeemOffer" method="post" class="mt-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="offerTitle" value="@offer.Title" />
                                    <input type="hidden" name="pointsCost" value="@offer.PointsCost" />
                                    <button type="submit" class="btn btn-primary btn-sm w-100">
                                        Redeem
                                    </button>
                                </form>
                            }
                            else
                            {
                                // Not enough points - show disabled button
                                <button type="button" class="btn btn-secondary btn-sm w-100 mt-3" disabled>
                                    Insufficient Points
                                </button>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-info">No offers available yet. Keep shopping to earn more points!</div>
                }
            </div>

            <!-- Action buttons - link to the available management tasks for this record -->
            <h3 class="mt-4 mb-3">Recent Transactions</h3>
            <div class="table-responsive">
                <!-- Loyalty account table - lists each record with its available actions -->
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Transaction Type</th>
                            <th>Points</th>
                            <th>Order ID</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Conditional section - shows this block only when the matching page state is true -->
                        @if (ViewBag.RecentTransactions != null && ViewBag.RecentTransactions.Count > 0)
                        {
                            <!-- Loop through each loyalty account record passed in from the controller -->
                            @foreach (var transaction in ViewBag.RecentTransactions)
                            {
                                <tr>
                                    <td>@transaction.transactionDate.ToString("dd MMM yyyy HH:mm")</td>
                                    <td>
                                        <!-- Conditional section - shows this block only when the matching page state is true -->
                                        @if (transaction.transactionType == "Earn")
                                        {
                                            <span class="badge bg-success">Earned</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Redeemed</span>
                                        }
                                    </td>
                                    <td class="@(transaction.transactionType == "Earn" ? "text-success" : "text-danger")">
                                        @(transaction.transactionType == "Earn" ? "+" : "-")@transaction.loyaltyPoints
                                    </td>
                                    <td>
                                        <!-- Conditional section - shows this block only when the matching page state is true -->
                                        @if (transaction.ordersId != null && transaction.ordersId > 0)
                                        {
                                            <a href="@Url.Action("Details", "orders", new { id = transaction.ordersId })">#@transaction.ordersId</a>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>
                                        <!-- Conditional section - shows this block only when the matching page state is true -->
                                        @if (transaction.ordersId != null && transaction.ordersId > 0)
                                        {
                                            <a href="@Url.Action("Details", "orders", new { id = transaction.ordersId })" class="btn btn-sm btn-outline-primary">View Order</a>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center">No transactions yet. Start shopping to earn points!</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Action buttons - link to the available management tasks for this record -->
            <div class="text-center mt-3">
                <a asp-action="TransactionHistory" class="btn btn-outline-primary">View All Transactions</a>
            </div>
        </div>
    </div>
</div>
