<!-- Link the page-specific stylesheet for the about page -->
@section Styles {
    <link rel="stylesheet" href="~/css/pages/home/about.css" asp-append-version="true" />
}

  <!-- About page wrapper - contains the full cooperative story layout -->
  <div class="page active" id="page-about">
    <!-- ========== page hero (exactly as original index) ========== -->
    <div class="page-hero">
      <!-- Page hero section - introduces the about page and gives visitors the main context -->
      <div class="page-hero-inner">
        <span class="page-eyebrow">Who We Are</span>
        <h1>About Greenfield Local Hub</h1>
        <p>A cooperative of local farmers and food producers working together to bring fresh, traceable food to our community.</p>
      </div>
    </div>

<!-- Content section - groups related about content together -->
<section class="section section-green">
  <div class="section-inner">
    <div class="about-grid">
      <div>
        <span class="section-eyebrow">Our Mission</span>
        <h2 class="section-title">Connecting communities through honest food</h2>
        <p style="color:var(--text-muted);font-size:.93rem;line-height:1.8;margin-top:.8rem;">GLH was founded by a group of local farmers who wanted to cut out the middleman and sell direct to their community. Today we represent 28 farms and food producers, serving over 4,000 customers across the region.</p>
        <p style="color:var(--text-muted);font-size:.93rem;line-height:1.8;margin-top:.75rem;">Every product sold through GLH supports a real farmer, keeps money in the local economy, and provides full traceability from farm to fork.</p>
      </div>
<div>
  <img src="/images/about/about.jpg" alt="Farm to Table" class="img-placeholder landscape" style="background: none; border: none; object-fit: cover;">
</div>
    </div>
  </div>
</section>

    <!-- Content section - groups related about content together -->
    <section class="section" style="background:var(--white);">
      <div class="section-inner">
        <!-- Centered content block - keeps the local benefits text easy to read -->
        <div style="max-width: 560px;">
          <span class="section-eyebrow">Why Local Matters</span>
          <h2 class="section-title">Benefits of buying locally</h2>
          <p style="color:var(--text-muted);font-size:.93rem;line-height:1.8;margin-top:.8rem;">Buying locally grown food helps support farmers and producers within your community. It keeps money circulating in the local economy and helps small businesses continue to grow and provide jobs.</p>
          <p style="color:var(--text-muted);font-size:.93rem;line-height:1.8;margin-top:.75rem;">Local food is often fresher because it travels a shorter distance from farm to table. This also reduces transportation emissions and allows customers to better understand where their food comes from and how it was produced.</p>
        </div>
      </div>
    </section>

    <!-- Content section - groups related about content together -->
    <section class="section section-green">
      <div class="section-inner">
        <div style="text-align:center;max-width:560px;margin:0 auto 3rem;">
          <span class="section-eyebrow">What We Stand For</span>
          <h2 class="section-title">Our Values</h2>
        </div>
        <div class="values-grid">
          <div class="value-card">
            <div class="value-card-icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none"><path d="M12 2a9 9 0 01-9 9M12 2a9 9 0 009 9M12 2v20" /></svg></div>
            <h3 class="value-card-title">Sustainability</h3>
            <p class="value-card-desc">We only partner with producers who demonstrate genuine commitment to sustainable farming practices and environmental stewardship.</p>
          </div>
          <div class="value-card">
            <div class="value-card-icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg></div>
            <h3 class="value-card-title">Transparency</h3>
            <p class="value-card-desc">Every product carries full traceability information so you can see exactly where your food was grown, by whom, and how.</p>
          </div>
          <div class="value-card">
            <div class="value-card-icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg></div>
            <h3 class="value-card-title">Community</h3>
            <p class="value-card-desc">We reinvest in local food networks, support new producers, and run regular community events throughout the year.</p>
          </div>
          <div class="value-card">
            <div class="value-card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 7c0-5.333-8-5.333-8 0" /><path d="M10 7v14" /><path d="M6 21h12" /><path d="M6 13h10" /></svg></div>
            <h3 class="value-card-title">Fair Pricing</h3>
            <p class="value-card-desc">Producers set their prices freely. GLH takes a small commission on each transaction with complete transparency.</p>
          </div>
          <div class="value-card">
            <div class="value-card-icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z" /><circle cx="12" cy="12" r="3" /></svg></div>
            <h3 class="value-card-title">Accessibility</h3>
            <p class="value-card-desc">Our platform is designed for everyone. We follow WCAG 2.1 AA guidelines and support a wide range of access needs.</p>
          </div>
          <div class="value-card">
            <div class="value-card-icon"><svg viewBox="0 0 24 24" stroke="currentColor" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg></div>
            <h3 class="value-card-title">Local First</h3>
            <p class="value-card-desc">All producers are within 30 miles of our hub. Shorter supply chains mean fresher food, fewer miles, lower emissions.</p>
          </div>
        </div>
      </div>
    </section>


<!-- Toast notification - provides temporary feedback for page-level actions -->
<div id="toast" role="status" aria-live="polite">✓ Full-width layout applied — sections stretch edge-to-edge</div>
