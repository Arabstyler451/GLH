@{
    ViewData["Title"] = "Terms & Conditions";
}

<!-- Link the page-specific stylesheet for the terms page -->
@section Styles {
    <link rel="stylesheet" href="~/css/pages/home/terms.css" asp-append-version="true" />
}

<!-- Terms page wrapper that contains the full terms and conditions layout -->
<div class="termsPage">

    <!-- Terms hero section - introduces the page and explains what the terms cover -->
    <section class="termsHero" aria-labelledby="termsHeading">
        <div class="termsHeroInner">
            <span class="termsEyebrow">Terms &amp; Conditions</span>
            <h1 class="termsHeading" id="termsHeading">Terms For Shopping With And Joining Greenfield Local Hub</h1>
            <p class="termsLead">
                These Terms and Conditions explain the basis on which customers and cooperative members use Greenfield
                Local Hub, place orders, receive deliveries or collections, and participate in our community-owned
                farmers market.
            </p>
            <!-- Key terms details shown as quick reference information for visitors -->
            <div class="termsMetaList" aria-label="Terms details">
                <div class="termsMetaItem">
                    <span class="termsMetaLabel">Last Updated</span>
                    <span class="termsMetaValue">23 April 2026</span>
                </div>
                <div class="termsMetaItem">
                    <span class="termsMetaLabel">Relevant Law</span>
                    <span class="termsMetaValue">Consumer Rights Act 2015 and applicable UK consumer law</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Main terms container that holds the summary cards, navigation and legal sections -->
    <div class="termsContainer">

        <!-- Summary panel section - highlights the most important themes before the full terms -->
        <section class="termsSummaryPanel" aria-label="Summary of key terms">
            <div class="termsSummaryCard">
                <span class="termsSummaryTitle">Local Cooperative</span>
                <p class="termsSummaryText">Orders and membership sit within a community-owned model designed to support local producers and fair participation.</p>
            </div>
            <div class="termsSummaryCard">
                <span class="termsSummaryTitle">Clear Consumer Rights</span>
                <p class="termsSummaryText">Nothing in these terms removes rights you have under the Consumer Rights Act 2015 or other UK consumer protections.</p>
            </div>
            <div class="termsSummaryCard">
                <span class="termsSummaryTitle">Fresh Food Logistics</span>
                <p class="termsSummaryText">Because many goods are fresh or perishable, timing, substitutions, and collection windows matter to how orders are fulfilled.</p>
            </div>
        </section>

        <!-- Content grid section - places the page navigation beside the full terms content -->
        <div class="termsContentGrid">

            <!-- Side navigation panel - links to each terms section on the page -->
            <aside class="termsSidePanel" aria-label="Terms navigation">
                <div class="termsSidePanelInner">
                    <p class="termsSideTitle">On This Page</p>
                    <a class="termsSideLink" href="#ourContractWithYou">Our Contract With You</a>
                    <a class="termsSideLink" href="#cooperativeMembershipRules">Cooperative Membership Rules</a>
                    <a class="termsSideLink" href="#orderingAndPayments">Ordering And Payments</a>
                    <a class="termsSideLink" href="#deliveryAndCollection">Delivery And Collection</a>
                    <a class="termsSideLink" href="#returnsAndRefunds">Returns And Refunds</a>
                    <a class="termsSideLink" href="#qualityOfGoods">Quality Of Goods</a>
                    <a class="termsSideLink" href="#liability">Liability</a>
                    <a class="termsSideLink" href="#disputeResolution">Dispute Resolution</a>
                    <a class="termsSideLink" href="#changesToTerms">Changes To Terms</a>
                    <a class="termsSideLink" href="#governingLaw">Governing Law</a>
                </div>
            </aside>

            <!-- Terms sections wrapper containing each detailed legal topic -->
            <div class="termsSections">

                <!-- Contract section - explains when the customer or membership agreement begins -->
                <section class="termsSection" id="ourContractWithYou">
                    <span class="termsSectionEyebrow">Contract</span>
                    <h2 class="termsSectionHeading">Our Contract With You</h2>
                    <p class="termsParagraph">
                        These Terms apply when you browse our website, create an account, place an order, or join
                        Greenfield Local Hub as a cooperative member. A contract for the purchase of goods is formed
                        when we accept your order and send confirmation, subject to product availability and any
                        necessary verification.
                    </p>
                    <p class="termsParagraph">
                        Membership of the cooperative is separate from a one-off customer purchase. Where you apply to
                        become a member, membership will begin once your application is accepted, any required member
                        share or subscription has been received, and you are recorded in the cooperative's membership records.
                    </p>
                </section>

                <!-- Cooperative membership section - outlines the rules and expectations for members -->
                <section class="termsSection" id="cooperativeMembershipRules">
                    <span class="termsSectionEyebrow">Membership</span>
                    <h2 class="termsSectionHeading">Cooperative Membership Rules</h2>
                    <!-- Feature cards summarising the main membership responsibilities and rights -->
                    <div class="termsFeatureGrid">
                        <article class="termsFeatureCard">
                            <h3 class="termsFeatureHeading">Voting Rights</h3>
                            <p class="termsFeatureText">Eligible members normally have one vote each on cooperative matters, regardless of purchase volume, subject to the cooperative's governing rules.</p>
                        </article>
                        <article class="termsFeatureCard">
                            <h3 class="termsFeatureHeading">Share Requirements</h3>
                            <p class="termsFeatureText">Where applicable, members may be required to hold a minimum member share or pay a membership contribution before voting rights or other member benefits begin.</p>
                        </article>
                        <article class="termsFeatureCard">
                            <h3 class="termsFeatureHeading">Member Conduct</h3>
                            <p class="termsFeatureText">Members must act honestly, provide accurate information, respect producers and staff, and avoid conduct that harms the cooperative or its community.</p>
                        </article>
                        <article class="termsFeatureCard">
                            <h3 class="termsFeatureHeading">Suspension Or Removal</h3>
                            <p class="termsFeatureText">We may suspend or terminate membership where there is serious breach of the cooperative's rules, non-payment, misuse of services, or unlawful behaviour.</p>
                        </article>
                    </div>
                </section>

                <!-- Ordering and payments section - explains how products, prices and payments are handled -->
                <section class="termsSection" id="orderingAndPayments">
                    <span class="termsSectionEyebrow">Orders</span>
                    <h2 class="termsSectionHeading">Ordering And Payments</h2>
                    <p class="termsParagraph">
                        Product listings, pricing, weights, and availability are shown as accurately as possible, but
                        seasonal and farm-supplied goods may occasionally vary. If a listed item is unavailable, we may
                        contact you about substitution, partial fulfilment, or refund options.
                    </p>
                    <!-- Order requirements list showing the key payment and account information rules -->
                    <div class="termsListCard">
                        <ul class="termsList">
                            <li class="termsListItem">Prices are shown in pounds sterling and include VAT where applicable.</li>
                            <li class="termsListItem">Payment is due at the point of order unless we expressly offer another method.</li>
                            <li class="termsListItem">You must provide accurate billing, delivery, and account information.</li>
                            <li class="termsListItem">Nothing in these Terms affects your statutory rights under the Consumer Rights Act 2015.</li>
                        </ul>
                    </div>
                </section>

                <!-- Delivery and collection section - explains how local fulfilment windows work -->
                <section class="termsSection" id="deliveryAndCollection">
                    <span class="termsSectionEyebrow">Fulfilment</span>
                    <h2 class="termsSectionHeading">Delivery And Collection</h2>
                    <p class="termsParagraph">
                        We deliver and arrange collection within our local farmers market catchment area. Delivery slots
                        and collection windows are estimates and may vary because of harvest schedules, producer dispatch
                        timing, traffic conditions, weather, or operational demand.
                    </p>
                    <!-- Timeline cards describing the main delivery, collection and inspection steps -->
                    <div class="termsTimeline">
                        <article class="termsTimelineItem">
                            <span class="termsTimelinePeriod">Home Delivery</span>
                            <p class="termsTimelineText">Please ensure someone is available to receive chilled, frozen, or perishable goods where needed. We may leave goods only in accordance with your delivery instructions and where reasonable.</p>
                        </article>
                        <article class="termsTimelineItem">
                            <span class="termsTimelinePeriod">Collection</span>
                            <p class="termsTimelineText">Collection orders must be picked up within the stated window. If collection is missed, we may be unable to retain perishable items for health, safety, or quality reasons.</p>
                        </article>
                        <article class="termsTimelineItem">
                            <span class="termsTimelinePeriod">Inspection</span>
                            <p class="termsTimelineText">Please inspect goods as soon as reasonably possible and notify us promptly if an item is incorrect, missing, damaged, or unsuitable on arrival.</p>
                        </article>
                    </div>
                </section>

                <!-- Returns and refunds section - explains cancellation rights and faulty goods protections -->
                <section class="termsSection" id="returnsAndRefunds">
                    <span class="termsSectionEyebrow">Returns</span>
                    <h2 class="termsSectionHeading">Returns And Refunds</h2>
                    <p class="termsParagraph">
                        Your cancellation and refund rights depend on the type of goods ordered. Under UK consumer law,
                        many distance purchases include a 14-day cooling-off period, but this does not usually apply to
                        goods that are liable to deteriorate or expire rapidly, including many fresh food items sold through our market.
                    </p>
                    <!-- Notice card highlighting statutory refund rights under UK consumer law -->
                    <div class="termsNoticeCard">
                        <p class="termsNoticeText">
                            If goods are faulty, not as described, unfit for purpose, or otherwise not in line with your
                            statutory rights, you may be entitled to repair, replacement, price reduction, or refund under
                            the Consumer Rights Act 2015.
                        </p>
                    </div>
                    <p class="termsParagraph">
                        Refunds approved by us will be made to the original payment method unless otherwise agreed. We may
                        ask for photographs, batch details, or prompt return where relevant to assess a reported issue.
                    </p>
                </section>

                <!-- Quality of goods section - explains the expected legal standards for products -->
                <section class="termsSection" id="qualityOfGoods">
                    <span class="termsSectionEyebrow">Consumer Rights</span>
                    <h2 class="termsSectionHeading">Quality Of Goods</h2>
                    <p class="termsParagraph">
                        We expect all goods sold through Greenfield Local Hub to meet the standards required by law,
                        including that goods are of satisfactory quality, fit for purpose, and as described, taking into
                        account the nature of local, seasonal, and handmade food products where relevant.
                    </p>
                    <!-- Feature cards showing the three main quality standards customers can expect -->
                    <div class="termsFeatureGrid termsFeatureGridTight">
                        <article class="termsFeatureCard">
                            <h3 class="termsFeatureHeading">Satisfactory Quality</h3>
                            <p class="termsFeatureText">Goods should meet the standard a reasonable person would consider satisfactory, considering description, price, and surrounding circumstances.</p>
                        </article>
                        <article class="termsFeatureCard">
                            <h3 class="termsFeatureHeading">Fitness For Purpose</h3>
                            <p class="termsFeatureText">Where you make known a particular purpose for goods, your statutory rights may apply if they are not suitable for that purpose.</p>
                        </article>
                        <article class="termsFeatureCard">
                            <h3 class="termsFeatureHeading">As Described</h3>
                            <p class="termsFeatureText">Goods should match their description, subject to reasonable natural variation in fresh produce and handmade or artisan items.</p>
                        </article>
                    </div>
                </section>

                <!-- Liability section - sets out what liability is and is not limited by the terms -->
                <section class="termsSection" id="liability">
                    <span class="termsSectionEyebrow">Liability</span>
                    <h2 class="termsSectionHeading">Liability</h2>
                    <p class="termsParagraph">
                        Nothing in these Terms excludes or limits liability where it would be unlawful to do so,
                        including liability for death or personal injury caused by negligence, fraud, fraudulent
                        misrepresentation, or breach of rights that cannot legally be excluded under UK law.
                    </p>
                    <p class="termsParagraph">
                        Subject to the above, we are not responsible for losses that were not foreseeable, losses caused
                        by your failure to follow care, storage, reheating, or allergen instructions, or business losses
                        suffered by non-consumer purchasers unless expressly agreed in writing.
                    </p>
                </section>

                <!-- Dispute resolution section - explains how concerns and unresolved disputes are handled -->
                <section class="termsSection" id="disputeResolution">
                    <span class="termsSectionEyebrow">Disputes</span>
                    <h2 class="termsSectionHeading">Dispute Resolution</h2>
                    <p class="termsParagraph">
                        If a concern arises, please contact us first so we can try to resolve it quickly and fairly. We
                        encourage early discussion, supporting documents, and practical solutions where possible.
                    </p>
                    <p class="termsParagraph">
                        If a dispute cannot be resolved informally, either party may pursue the matter through the courts.
                        Where appropriate and available, claims may be brought through the small claims track of the courts
                        in the relevant UK jurisdiction.
                    </p>
                </section>

                <!-- Changes to terms section - explains how updates to the terms will be published -->
                <section class="termsSection" id="changesToTerms">
                    <span class="termsSectionEyebrow">Updates</span>
                    <h2 class="termsSectionHeading">Changes To Terms</h2>
                    <p class="termsParagraph">
                        We may update these Terms from time to time to reflect legal, operational, technical, or
                        cooperative governance changes. The latest version will always be published on our website with
                        the updated effective date.
                    </p>
                    <p class="termsParagraph">
                        If a change materially affects existing members or active services, we will take reasonable steps
                        to bring it to your attention, such as by website notice or email.
                    </p>
                </section>

                <!-- Governing law section - explains which UK laws apply to these terms -->
                <section class="termsSection" id="governingLaw">
                    <span class="termsSectionEyebrow">Law</span>
                    <h2 class="termsSectionHeading">Governing Law</h2>
                    <!-- Notice card showing the jurisdiction and local court rights for UK consumers -->
                    <div class="termsNoticeCard termsNoticeCardGreen">
                        <p class="termsNoticeText">
                            These Terms are governed by the laws of England and Wales. If you are a consumer resident in
                            Scotland or Northern Ireland, you may also benefit from any mandatory provisions of the law of
                            your part of the United Kingdom, and you may bring proceedings in your local courts where permitted.
                        </p>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>
