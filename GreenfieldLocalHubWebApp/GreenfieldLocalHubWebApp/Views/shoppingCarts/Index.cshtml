@model IEnumerable<GreenfieldLocalHubWebApp.Models.shoppingCartItems>

@{
    ViewData["Title"] = "Your Shopping Cart";
    var shoppingCartId = Model.FirstOrDefault()?.shoppingCartId;
    var activeOffersList = ViewBag.ActiveOffers as List<string> ?? new List<string>();
    var pendingOffer = ViewBag.PendingOffer as string;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet">

@section Styles {
    <link rel="stylesheet" href="~/css/pages/shoppingCarts/index.css" asp-append-version="true" />
}

<!-- PAGE HERO -->
<div class="page-hero">
    <div class="page-hero-inner">
        <nav class="breadcrumb" aria-label="Breadcrumb">
            <a asp-controller="products" asp-action="Index">Shop</a>
            <span class="breadcrumb-sep">›</span>
            <span aria-current="page">Your Cart</span>
        </nav>
        <span class="page-eyebrow">Basket</span>
        <h1>Your Shopping Cart</h1>
    </div>
</div>

<!-- CART CONTENT -->
<div class="cart-section">

    @if (!Model.Any())
    {
        <!-- EMPTY STATE -->
        <div class="empty-cart">
            <div class="empty-cart-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <path d="M16 10a4 4 0 01-8 0" />
                </svg>
            </div>
            <h3>Your basket is empty</h3>
            <p>You haven't added any products yet. Browse our local produce and add something fresh.</p>
            <a asp-controller="products" asp-action="Index" class="btn btn-primary btn-inline">
                Browse Products
            </a>
        </div>
    }
    else
    {
        <div class="cart-layout">

            <!-- LEFT: CART ITEMS -->
            <div>
                <table class="cart-table" role="table" aria-label="Shopping cart items">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Unit Price</th>
                            <th>Qty</th>
                            <th>Line Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <!-- PRODUCT -->
                                <td>
                                    <div class="cart-product">
                                        @if (!string.IsNullOrEmpty(item.products?.productImage))
                                        {
                                            <div class="cart-product-thumb">
                                                <img src="@item.products.productImage" alt="@item.products.productName" />
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="img-placeholder-sm">IMG</div>
                                        }
                                        <div class="cart-product-info">
                                            <strong>@item.products?.productName</strong>
                                            @if (item.products?.categories != null)
                                            {
                                                <small>@item.products.categories.categoryName</small>
                                            }
                                        </div>
                                    </div>
                                </td>

                                <!-- UNIT PRICE -->
                                <td>
                                    <span class="cart-price">£@item.products?.productPrice.ToString("0.00")</span>
                                </td>

                                <!-- QTY -->
                                <td>
                                    <div style="display:flex;align-items:center;gap:.4rem;">
                                        <form asp-controller="shoppingCartItems" asp-action="UpdateQuantity" method="post" style="display:contents;">
                                            <input type="hidden" name="shoppingCartItemsId" value="@item.shoppingCartItemsId" />
                                            <input type="hidden" name="change" value="-1" />
                                            <button type="submit" class="qty-btn" aria-label="Decrease quantity" @(item.quantity <= 1 ? "disabled" : "")>−</button>
                                        </form>

                                        <span class="cart-qty">@item.quantity</span>

                                        <form asp-controller="shoppingCartItems" asp-action="UpdateQuantity" method="post" style="display:contents;">
                                            <input type="hidden" name="shoppingCartItemsId" value="@item.shoppingCartItemsId" />
                                            <input type="hidden" name="change" value="1" />
                                            <button type="submit" class="qty-btn" aria-label="Increase quantity" @(item.quantity >= item.products?.stockQuantity ? "disabled" : "")>+</button>
                                        </form>
                                    </div>
                                </td>

                                <!-- LINE TOTAL -->
                                <td>
                                    <span class="cart-line-total">
                                        £@((item.products != null ? item.products.productPrice * item.quantity : 0).ToString("0.00"))
                                    </span>
                                </td>

                                <!-- REMOVE -->
                                <td class="cart-item-actions">
                                    <form asp-controller="shoppingCartItems"
                                          asp-action="Delete"
                                          asp-route-id="@item.shoppingCartItemsId"
                                          method="post"
                                          style="display: inline;">
                                        <input type="hidden" name="shoppingCartItemsId" value="@item.shoppingCartItemsId" />
                                        <button type="submit" class="btn-remove" aria-label="Remove @item.products?.productName from cart">
                                            Remove
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <!-- CONTINUE SHOPPING -->
                <div style="margin-top:1.25rem;">
                    <a asp-controller="products" asp-action="Index" class="btn btn-ghost btn-inline" style="width:auto;display:inline-flex;">
                        ← Continue Shopping
                    </a>
                </div>
            </div>

            <!-- RIGHT: ORDER SUMMARY -->
            <aside>
                <div class="order-summary">
                    <h2 class="summary-title">Order Summary</h2>

                    <div class="summary-row">
                        <span>Subtotal</span>
                        <span>£@(((float)(ViewBag.subTotalAmount ?? 0f)).ToString("0.00"))</span>
                    </div>

                    <div class="summary-row">
                        <span>Loyalty Discount</span>
                        <span style="color:#1a6b40;">−£@(((float)(ViewBag.loyaltyDiscount ?? 0f)).ToString("0.00"))</span>
                    </div>

                    <div class="summary-row">
                        <span>Delivery</span>
                        <span style="color:#1a6b40;">Calculated at checkout</span>
                    </div>

                    <div class="summary-row total">
                        <span>Total</span>
                        <span>£@(((float)(ViewBag.total ?? 0f)).ToString("0.00"))</span>
                    </div>

                    @if (activeOffersList.Any())
                    {
                        <div style="margin-bottom:1.25rem; padding-bottom:1.25rem; border-bottom:1px solid var(--border);">
                            <p style="font-size:.75rem; font-weight:600; letter-spacing:.08em;
                                text-transform:uppercase; color:var(--text-muted); margin-bottom:.75rem;">
                                Loyalty Offer
                            </p>

                            <form asp-controller="shoppingCarts" asp-action="ApplyOffer" method="post">
                                @Html.AntiForgeryToken()
                                <div style="display:flex; gap:.5rem; align-items:stretch;">
                                    <select name="selectedOffer"
                                            style="flex:1; padding:.55rem .75rem;
                                        border:1.5px solid var(--border);
                                        font-family:var(--font-sans); font-size:.82rem;
                                        color:var(--text); background:var(--white);
                                        appearance:none; -webkit-appearance:none;
                                        background-image:url('data:image /svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'10\' height=\'6\'><path d=\'M0 0l5 6 5-6z\' fill=\'%236B6B6B\'/></svg>');
                                        background-repeat:no-repeat;
                                        background-position:right .65rem center;">

                                        @{
                                            var noneSelected = string.IsNullOrEmpty(pendingOffer);
                                        }
                                        <option value="none" selected="@noneSelected">— No offer —</option>

                                        @foreach (var offer in activeOffersList)
                                        {
                                            var isSelected = (pendingOffer == offer);
                                            <option value="@offer" selected="@isSelected">@offer</option>
                                        }

                                    </select>
                                    <button type="submit"
                                            class="btn btn-primary"
                                            style="width:auto; margin:0; padding:.55rem 1rem; font-size:.82rem;">
                                        Apply
                                    </button>
                                </div>
                            </form>

                            @if (!string.IsNullOrEmpty(pendingOffer))
                            {
                                <p style="margin-top:.6rem; font-size:.78rem; color:#1a6b40; font-weight:500;">
                                    ✓ "@pendingOffer" applied
                                </p>
                            }
                        </div>
                    }

                    <div style="margin-top:1.5rem;">
                        <a asp-controller="orders"
                               asp-action="Create"
                               asp-route-shoppingCartId="@shoppingCartId"
                               class="btn btn-primary">
                            Proceed to Checkout
                        </a>
                        <a asp-controller="products" asp-action="Index" class="btn btn-ghost">
                            Continue Shopping
                        </a>
                    </div>

                    <!-- TRUST STRIP -->
                    <div class="trust-strip">
                        <div class="trust-item">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                            Secure checkout
                        </div>
                        <div class="trust-item">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                            Next-day delivery
                        </div>
                        <div class="trust-item">
                            <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12" /></svg>
                            100% local produce
                        </div>
                    </div>
                </div>
            </aside>

        </div>
    }

</div>

