@model GreenfieldLocalHubWebApp.Models.orderProducts

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>orderProducts</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="orderProductsId" />
            <div class="form-group">
                <label asp-for="ordersId" class="control-label"></label>
                <select asp-for="ordersId" class="form-control" asp-items="ViewBag.ordersId"></select>
                <span asp-validation-for="ordersId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="productsId" class="control-label"></label>
                <select asp-for="productsId" class="form-control" asp-items="ViewBag.productsId"></select>
                <span asp-validation-for="productsId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="quantity" class="control-label"></label>
                <input asp-for="quantity" class="form-control" />
                <span asp-validation-for="quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="unitPrice" class="control-label"></label>
                <input asp-for="unitPrice" class="form-control" />
                <span asp-validation-for="unitPrice" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
